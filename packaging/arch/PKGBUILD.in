pkgname=cockpit-slurm
pkgver=VERSION
pkgrel=1
pkgdesc='Cockpit SLURM Example Module'
arch=('x86_64')
url='https://github.com/lingweicai/cockpit-slurm'
license=(LGPL)
source=("SOURCE")
sha256sums=('SKIP')

makedepends=('go' 'make')

package() {
  depends=(cockpit)
  cd $pkgname
  make DESTDIR="$pkgdir" install PREFIX=/usr
}
